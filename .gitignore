# PlatformIO
.pio/
.vscode/
compile_commands.json
road_map.bin
# Build artifacts under release/ are ignored individually.
release/*
# Defense in depth: never track private key material.
release/keys/*priv*
release/keys/*.seed
release/keys/*.secret
*.priv.key
*private*.key
*_private.key
*.seed
id_ed25519
id_rsa

# Local environment and credentials
.env
.env.*
!.env.example
!.env.sample
.netrc
.npmrc
.pypirc
credentials*.json
*credentials*.json
secrets*.json
*secret*.json
*.pem
*.p12
*.pfx

# Python virtual environment
.venv/
__pycache__/
*.pyc

# macOS
.DS_Store
__MACOSX/

# Build artifacts
*.o
*.bin
*.elf
*.zip
*.log
!test/fixtures/debug_base_stable.log
artifacts/
.artifacts/

# Font files (source fonts, converted to headers)
/*.ttf

# IDE
.idea/
*.iml
.clangd

# Temporary/development files
RDF_POST*
*.tmp
*~
*.bak

# Local planning/review docs (not tracked)
docs/plans/
docs/reviews/
PRODUCTION_READINESS_REVIEW.md
FEATURE_MIGRATION_PLAN.md
