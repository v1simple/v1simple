    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.7",
    "daisyui": "^5.5.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.32",
    "svelte": "^5.0.0",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "type": "module",
