*.sr
*.pvs
alp_captures/

# Local research docs (not tracked)
docs/CODEBASE_LEARNING_BRIEF.local.md
docs/FUNCTION_PRIORITY.local.md
# docs/ALP_*.md — ALP protocol reference + manual extracts.
#   ALP_MANUAL_EXTRACTS.md contains copyrighted manual content and MUST NOT
#   be committed. ALP_PROTOCOL_REFERENCE.md is our own analysis but stays
#   local. Only the sanitized evidence summary below is tracked.
docs/ALP_*.md
!docs/ALP_PROTOCOL_EVIDENCE.md
docs/CONSTITUTIONAL_FAILURES.md
# Local AI assistant instructions stay out of the repo.
.github/instructions/
.github/instrictions/
*.docx
.~lock.*
CLAUDE.md

# Local hardware lab config (template checked in, local values are not)
test/device/board_inventory.local.json
test/device/board_inventory.local.json.sig
test/device/board_inventory_signing_key.local
test/device/board_inventory_signing_key.local.pub
test/device/serial_ports.local.json
