/interface/node_modules/
/interface/.svelte-kit/
/interface/build/
/interface/.vite/
/interface/.DS_Store

# Deployed web UI (generated from interface/)
/data/

# Large files (schematics, datasheets)
*.pdf

# Images (unless needed for docs)
*.png
!docs/*.png
!interface/static/branding/*.png

# Audio source files (keep generated headers, not source audio)
*.aiff
*.raw
*.wav
*.mp3

