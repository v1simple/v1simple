#!/usr/bin/env bash
# Enforce the project's commit-message contract:  <type>(<scope>): short summary
#
# Install:  ./scripts/setup-hooks.sh
# Bypass:   git commit --no-verify   (only if you truly mean to)

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
exec python3 "$ROOT/scripts/check_commit_msg.py" "$1"
