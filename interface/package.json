{
  "name": "v1simple-interface",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && bash ../tools/compress_web_assets.sh",
